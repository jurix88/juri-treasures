class AIRecognitionService {
  static final AIRecognitionService _instance = AIRecognitionService._internal();
  factory AIRecognitionService() => _instance;
  AIRecognitionService._internal();

  Future<RecognitionResult> recognizeFromImage(File imageFile) async {
    await Future.delayed(const Duration(seconds: 2));
    final categories = ItemCategory.values;
    final randomCategory = categories[Random().nextInt(categories.length)];

    return RecognitionResult(
      category: randomCategory,
      confidence: 0.7 + Random().nextDouble() * 0.25,
      suggestions: [
        ItemCategory.muenze,
        ItemCategory.gold,
        ItemCategory.sonstiges
      ],
      extractedText: 'Erkannter Text: 999.9 Feinsilber',
      estimatedYear: 1980 + Random().nextInt(40),
    );
  }

  Future<double> estimateValue({
    required ItemCategory category,
    int? year,
    String? condition,
    String? rarity,
    String? extractedText,
  }) async {
    double baseValue = 50.0;
    switch (category) {
      case ItemCategory.muenze:
        baseValue = 100.0;
        if (year != null && year < 1900) baseValue *= 3.0;
        break;
      case ItemCategory.uhren:
        baseValue = 500.0;
        if (year != null && year < 1980) baseValue *= 2.5;
        break;
      case ItemCategory.gold:
        baseValue = 1000.0;
        break;
      case ItemCategory.gemalde:
        baseValue = 2000.0;
        break;
      case ItemCategory.briefmarke:
        baseValue = 10.0;
        break;
      default:
        baseValue = 100.0;
    }

    double conditionMultiplier = {
      'mint': 2.0,
      'veryGood': 1.5,
      'good': 1.0,
      'fair': 0.6,
      'poor': 0.3
    }[condition] ?? 1.0;

    double rarityMultiplier = {
      'unique': 10.0,
      'veryRare': 5.0,
      'rare': 2.5,
      'uncommon': 1.5
    }[rarity] ?? 1.0;

    return double
        .parse((baseValue * conditionMultiplier * rarityMultiplier)
            .toStringAsFixed(2));
  }
}

class RecognitionResult {
  final ItemCategory category;
  final double confidence;
  final List<ItemCategory> suggestions;
  final String? extractedText;
  final int? estimatedYear;

  RecognitionResult({
    required this.category,
    required this.confidence,
    required this.suggestions,
    this.extractedText,
    this.estimatedYear,
  });
}

