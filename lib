class DatabaseService {
  static final DatabaseService _instance = DatabaseService._internal();
  factory DatabaseService() => _instance;
  DatabaseService._internal();

  List<AntiqueItem> _items = [];

  List<AntiqueItem> get items => List.unmodifiable(_items);

  Future<void> loadItems() async {
    try {
      final directory = await getApplicationDocumentsDirectory();
      final file = File('${directory.path}/antiques.json');
      if (await file.exists()) {
        final contents = await file.readAsString();
        final List<dynamic> jsonList = json.decode(contents);
        _items = jsonList.map((e) => AntiqueItem.fromJson(e)).toList();
      }
    } catch (e) {
      _items = [];
    }
  }

  Future<void> _saveItems() async {
    final directory = await getApplicationDocumentsDirectory();
    final file = File('${directory.path}/antiques.json');
    final jsonList = _items.map((e) => e.toJson()).toList();
    await file.writeAsString(json.encode(jsonList));
  }

  Future<void> addItem(AntiqueItem item) async {
    _items.add(item);
    await _saveItems();
  }

  Future<void> updateItem(AntiqueItem item) async {
    final index = _items.indexWhere((e) => e.id == item.id);
    if (index != -1) {
      _items[index] = item;
      await _saveItems();
    }
  }

  Future<void> deleteItem(String id) async {
    _items.removeWhere((e) => e.id == id);
    await _saveItems();
  }

  List<AntiqueItem> searchItems(String query) {
    final lowerQuery = query.toLowerCase();
    return _items
        .where((item) =>
            item.name.toLowerCase().contains(lowerQuery) ||
            (item.description?.toLowerCase().contains(lowerQuery) ?? false))
        .toList();
  }

  List<AntiqueItem> getItemsByCategory(int categoryIndex) {
    return _items
        .where((item) => item.category.index == categoryIndex)
        .toList();
  }

  double getTotalValue() {
    return _items.fold(
        0.0, (sum, item) => sum + (item.estimatedValue ?? 0));
  }
}

