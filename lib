class AntiqueItem {
  final String id;
  String name;
  String nameEn;
  ItemCategory category;
  String? description;
  String? descriptionEn;
  String? imagePath;
  List<String> galleryImages;
  double? purchasePrice;
  int? year;
  String? condition;
  String? rarity;
  double? estimatedValue;
  double? insuranceValue;
  DateTime createdAt;
  DateTime? lastUpdated;
  String? notes;
  bool isFavorite;
  List<ValueHistory> valueHistory;

  AntiqueItem({
    required this.id,
    required this.name,
    this.nameEn = '',
    required this.category,
    this.description,
    this.descriptionEn = '',
    this.imagePath,
    this.galleryImages = const [],
    this.purchasePrice,
    this.year,
    this.condition,
    this.rarity,
    this.estimatedValue,
    this.insuranceValue,
    required this.createdAt,
    this.lastUpdated,
    this.notes,
    this.isFavorite = false,
    this.valueHistory = const [],
  });

  Map<String, dynamic> toJson() => {
        'id': id,
        'name': name,
        'nameEn': nameEn,
        'category': category.index,
        'description': description,
        'descriptionEn': descriptionEn,
        'imagePath': imagePath,
        'galleryImages': galleryImages,
        'purchasePrice': purchasePrice,
        'year': year,
        'condition': condition,
        'rarity': rarity,
        'estimatedValue': estimatedValue,
        'insuranceValue': insuranceValue,
        'createdAt': createdAt.toIso8601String(),
        'lastUpdated': lastUpdated?.toIso8601String(),
        'notes': notes,
        'isFavorite': isFavorite,
        'valueHistory': valueHistory.map((e) => e.toJson()).toList(),
      };

  factory AntiqueItem.fromJson(Map<String, dynamic> json) => AntiqueItem(
        id: json['id'],
        name: json['name'],
        nameEn: json['nameEn'] ?? '',
        category: ItemCategory.values[json['category']],
        description: json['description'],
        descriptionEn: json['descriptionEn'] ?? '',
        imagePath: json['imagePath'],
        galleryImages: List<String>.from(json['galleryImages'] ?? []),
        purchasePrice: json['purchasePrice']?.toDouble(),
        year: json['year'],
        condition: json['condition'],
        rarity: json['rarity'],
        estimatedValue: json['estimatedValue']?.toDouble(),
        insuranceValue: json['insuranceValue']?.toDouble(),
        createdAt: DateTime.parse(json['createdAt']),
        lastUpdated: json['lastUpdated'] != null
            ? DateTime.parse(json['lastUpdated'])
            : null,
        notes: json['notes'],
        isFavorite: json['isFavorite'] ?? false,
        valueHistory: (json['valueHistory'] as List?)
                ?.map((e) => ValueHistory.fromJson(e))
                .toList() ??
            [],
      );
}

class ValueHistory {
  final DateTime date;
  final double value;
  final String? note;

  ValueHistory({required this.date, required this.value, this.note});

  Map<String, dynamic> toJson() =>
      {'date': date.toIso8601String(), 'value': value, 'note': note};

  factory ValueHistory.fromJson(Map<String, dynamic> json) => ValueHistory(
        date: DateTime.parse(json['date']),
        value: json['value'].toDouble(),
        note: json['note'],
      );
}

