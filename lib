class ValueCalculator {
  static double calculateEstimatedValue(AntiqueItem item) {
    double baseValue = item.purchasePrice ?? 100.0;

    if (item.year != null) {
      int age = DateTime.now().year - item.year!;
      if (age > 100)
        baseValue *= 1.5;
      else if (age > 50)
        baseValue *= 1.2;
    }

    double conditionMultiplier = _getConditionMultiplier(item.condition);
    double rarityMultiplier = _getRarityMultiplier(item.rarity);
    double categoryMultiplier = _getCategoryMultiplier(item.category);

    return double.parse((baseValue *
            conditionMultiplier *
            rarityMultiplier *
            categoryMultiplier)
        .toStringAsFixed(2));
  }

  static double _getConditionMultiplier(String? condition) {
    switch (condition) {
      case 'mint':
        return 1.5;
      case 'veryGood':
        return 1.3;
      case 'good':
        return 1.0;
      case 'fair':
        return 0.7;
      case 'poor':
        return 0.4;
      default:
        return 1.0;
    }
  }

  static double _getRarityMultiplier(String? rarity) {
    switch (rarity) {
      case 'unique':
        return 5.0;
      case 'veryRare':
        return 3.0;
      case 'rare':
        return 2.0;
      case 'uncommon':
        return 1.3;
      default:
        return 1.0;
    }
  }

  static double _getCategoryMultiplier(ItemCategory category) {
    switch (category) {
      case ItemCategory.gold:
        return 2.0;
      case ItemCategory.silber:
        return 1.5;
      case ItemCategory.uhren:
        return 1.8;
      case ItemCategory.gemalde:
        return 2.5;
      default:
        return 1.0;
    }
  }
}

